---
const year = new Date().getFullYear();
const whatsappUrl = 'https://wa.me/34623926731?text=Hola%20Natalia%2C%20quiero%20agendar%20una%20sesi%C3%B3n%20y%20recibir%20m%C3%A1s%20informaci%C3%B3n.';
---

<footer class="border-t border-brand-100 bg-warm-900 px-4 py-12 text-warm-100 md:px-8">
  <div class="mx-auto grid max-w-6xl gap-10 text-center md:grid-cols-4 md:text-left">
    <div class="flex flex-col items-center md:col-span-2 md:items-start">
      <div class="flex items-center justify-center gap-3 md:justify-start">
        <img src="/butterfly.svg" alt="Logo Natalia Porras" class="h-12 w-12 rounded-full border border-warm-200/20 bg-white p-1" />
        <p class="font-display text-3xl">Natalia Porras Psicología</p>
      </div>
      <p class="mt-4 max-w-md text-warm-200">Psicología con enfoque integrador para acompañarte en un espacio seguro, confidencial y libre de juicios.</p>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="mt-5 inline-block text-brand-300 transition-colors hover:text-brand-200">WhatsApp</a>
    </div>

    <div class="flex flex-col items-center md:items-start">
      <p class="font-semibold uppercase tracking-[0.14em] text-warm-300">Navegación</p>
      <ul class="mt-4 space-y-2 text-warm-200">
        <li><a href="#inicio" class="hover:text-white">Inicio</a></li>
        <li><a href="#sobre-mi" class="hover:text-white">Sobre mí</a></li>
        <li><a href="#servicios" class="hover:text-white">Servicios</a></li>
        <li><a href="#testimonios" class="hover:text-white">Testimonios</a></li>
      </ul>
    </div>

    <div class="flex flex-col items-center md:items-start">
      <p class="font-semibold uppercase tracking-[0.14em] text-warm-300">Especialidades</p>
      <ul class="mt-4 space-y-2 text-warm-200">
        <li>Vínculos</li>
        <li>Trauma</li>
        <li>EMDR</li>
        <li>Perinatal</li>
        <li>Regulación emocional</li>
        <li>Terapia de pareja</li>
      </ul>
    </div>
  </div>

  <div class="mx-auto mt-10 flex max-w-6xl flex-col items-center justify-between gap-3 border-t border-warm-700 pt-6 text-center text-sm text-warm-300 md:flex-row md:text-left">
    <p>© {year} Natalia Porras Psicología. Todos los derechos reservados.</p>
    <p>
      España · Online · Desarrollado por
      <a href="https://dailymp.es" target="_blank" rel="noopener noreferrer" class="font-medium text-brand-300 transition-colors hover:text-brand-200">DailyMP</a>
    </p>
  </div>
</footer>
