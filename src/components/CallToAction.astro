---
const whatsappUrl = 'https://wa.me/34623926731?text=Hola%20Natalia%2C%20quiero%20agendar%20una%20sesi%C3%B3n%20y%20recibir%20m%C3%A1s%20informaci%C3%B3n.';
---

<section class="px-4 pb-16 pt-8 md:px-8 md:pb-24">
  <div class="mx-auto max-w-6xl rounded-[2rem] bg-gradient-to-r from-brand-700 via-brand-600 to-accent-500 p-8 text-white shadow-card md:p-12">
    <div class="reveal flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div>
        <p class="font-accent text-4xl">Es tu momento</p>
        <h2 class="mt-1 font-display text-4xl md:text-5xl">Comienza tu proceso con una primera conversación</h2>
        <p class="mt-3 max-w-2xl text-white/90">Escríbeme por WhatsApp y te ayudo a definir el mejor camino terapéutico para ti.</p>
      </div>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex rounded-full bg-white px-7 py-3 font-semibold text-brand-700 transition-all duration-300 hover:scale-[1.03] hover:bg-warm-50">
        Hablar por WhatsApp
      </a>
    </div>
  </div>
</section>
