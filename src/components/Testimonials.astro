---
const testimonials = [
  {
    date: '8 de mayo de 2026',
    author: 'Paciente verificada',
    text: 'Vamos mi pareja y yo, y Natalia es una gran profesional, nos está ayudando mucho.'
  },
  {
    date: '17/04/2026',
    author: 'Paciente verificada',
    text: 'Todo bien. Muy atenta. Pareció muy interesada. Y me dio sensación de alguien cercano y muy humano.'
  },
  {
    date: '15/04/2026',
    author: 'Paciente verificada',
    text: 'Me siento muy cómodo y siento que entiende muy bien lo que necesito. Es una gran profesional.'
  },
  {
    date: '25/02/2026',
    author: 'Paciente verificada',
    text: 'Primera toma de contacto muy bien y agradable. Seguiremos trabajando.'
  },
  {
    date: '15/01/2026',
    author: 'Paciente verificada',
    text: 'Gran profesional y excelente persona. Eficaz y empática.'
  },
  {
    date: '26/11/2025',
    author: 'Paciente verificada',
    text: 'Fue la primera visita, pero nos transmitió profesionalidad y buena comunicación.'
  },
  {
    date: '17/09/2025',
    author: 'Paciente verificada',
    text: 'Muy buena profesional, escucha, atención y comprensión.'
  }
];
---

<section id="testimonios" class="px-4 py-16 md:px-8 md:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="reveal">
      <h2 class="section-title">Opiniones de pacientes</h2>
      <p class="section-subtitle mx-auto">Reseñas reales publicadas de forma anonimizada para preservar la privacidad de cada paciente.</p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <article class="reveal flex min-h-[232px] flex-col rounded-2xl border border-brand-100 bg-white/90 p-6 shadow-soft">
          <div class="flex items-center justify-between gap-4">
            <p class="text-lg tracking-[0.18em] text-[#00836f]" aria-label="5 estrellas">★★★★★</p>
            <p class="whitespace-nowrap rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-brand-700">
              Anonimizada
            </p>
          </div>
          <p class="mt-5 flex-1 text-base leading-relaxed text-warm-700">"{testimonial.text}"</p>
          <div class="mt-5 border-t border-brand-100 pt-4">
            <p class="text-sm font-semibold text-brand-700">{testimonial.author}</p>
            <p class="mt-1 text-sm text-warm-500">{testimonial.date}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
