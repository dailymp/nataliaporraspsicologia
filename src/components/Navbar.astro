---
const whatsappUrl = 'https://wa.me/34623926731?text=Hola%20Natalia%2C%20quiero%20agendar%20una%20sesi%C3%B3n%20y%20recibir%20m%C3%A1s%20informaci%C3%B3n.';
---

<header id="main-nav" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 md:px-8">
    <a href="#inicio" aria-label="Ir al inicio" class="group inline-flex items-center gap-3">
      <img src="/butterfly-logo.png" alt="Logo Natalia Porras Psicología" class="h-11 w-11 rounded-full bg-white object-contain p-1.5 ring-2 ring-brand-200" />
      <span class="font-display text-2xl text-warm-900 transition-colors group-hover:text-brand-700">Natalia Porras</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      <a class="nav-link" href="#sobre-mi" aria-label="Ir a sobre mi">Sobre mi</a>
      <a class="nav-link" href="#servicios" aria-label="Ir a servicios">Servicios</a>
      <a class="nav-link" href="#testimonios" aria-label="Ir a testimonios">Testimonios</a>
      <a class="nav-link" href="#faq" aria-label="Ir a preguntas frecuentes">FAQ</a>
      <a class="btn-primary" href={whatsappUrl} aria-label="Contactar por WhatsApp" target="_blank" rel="noopener noreferrer">Agendar por WhatsApp</a>
    </nav>

    <button id="menu-btn" aria-label="Abrir menu" class="inline-flex rounded-full border border-brand-200 bg-white/80 p-2 text-brand-700 md:hidden">
      <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" stroke="currentColor" stroke-width="1.8">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="mx-4 hidden rounded-2xl border border-brand-100 bg-warm-50/95 p-4 shadow-card backdrop-blur-sm md:hidden">
    <nav class="flex flex-col gap-3">
      <a class="nav-link" href="#sobre-mi" aria-label="Ir a sobre mi">Sobre mi</a>
      <a class="nav-link" href="#servicios" aria-label="Ir a servicios">Servicios</a>
      <a class="nav-link" href="#testimonios" aria-label="Ir a testimonios">Testimonios</a>
      <a class="nav-link" href="#faq" aria-label="Ir a preguntas frecuentes">FAQ</a>
      <a class="btn-primary text-center" href={whatsappUrl} aria-label="Contactar por WhatsApp" target="_blank" rel="noopener noreferrer">Agendar por WhatsApp</a>
    </nav>
  </div>
</header>
