---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Natalia Porras Psicología | Psicóloga en Málaga y online',
  description = 'Psicóloga General Sanitaria en Málaga y online. Terapia individual y de pareja para ansiedad, autoestima, trauma, apego, EMDR, embarazo, postparto y crianza.',
  canonical = 'https://nataliaporraspsicologia.com/'
} = Astro.props;

const siteUrl = 'https://nataliaporraspsicologia.com';
const socialImage = `${siteUrl}/natalia-porras-psicologia-og.jpg`;
const whatsappUrl = 'https://wa.me/34623926731?text=Hola%20Natalia%2C%20quiero%20agendar%20una%20sesi%C3%B3n%20y%20recibir%20m%C3%A1s%20informaci%C3%B3n.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Natalia Porras Psicología',
  description,
  url: canonical,
  sameAs: ['https://www.instagram.com/nataliaporraspsicologia/'],
  areaServed: [
    {
      '@type': 'City',
      name: 'Málaga'
    },
    {
      '@type': 'Country',
      name: 'España'
    }
  ],
  availableLanguage: ['es'],
  serviceType: ['Psicología clínica', 'Terapia individual', 'Terapia de pareja', 'EMDR', 'Terapia online'],
  knowsAbout: ['Ansiedad', 'Autoestima', 'Trauma', 'Apego', 'Relaciones', 'Regulación emocional', 'Embarazo', 'Postparto', 'Crianza'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Málaga',
    addressRegion: 'España',
    addressCountry: 'ES'
  },
  image: socialImage,
  priceRange: 'EUR EUR'
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="psicóloga en Málaga, psicóloga online, terapia psicológica, EMDR, ansiedad, autoestima, trauma, apego, terapia de pareja, embarazo, postparto, crianza, Natalia Porras" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f3c6cf" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es-ES" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1080" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:image:alt" content="Natalia Porras Psicología, acompañamiento psicológico en Málaga y online" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Natalia Porras Psicología" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Natalia Porras Psicología, acompañamiento psicológico en Málaga y online" />

    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" href="/logo.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />

    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="whatsapp-fab"
    >
      <svg viewBox="0 0 32 32" class="h-6 w-6" fill="currentColor" aria-hidden="true">
        <path d="M16.04 3C8.84 3 3 8.74 3 15.83c0 2.4.68 4.74 1.97 6.77L3 29l6.61-1.89a13.2 13.2 0 0 0 6.39 1.63h.05c7.2 0 13.04-5.74 13.04-12.83C29.1 8.74 23.25 3 16.04 3Zm0 23.55h-.04a10.9 10.9 0 0 1-5.56-1.53l-.4-.24-3.92 1.12 1.13-3.8-.26-.4a10.55 10.55 0 0 1-1.65-5.62c0-5.86 4.82-10.62 10.73-10.62s10.74 4.76 10.74 10.62c0 5.86-4.82 10.62-10.73 10.62Zm5.88-8.03c-.33-.16-1.96-.96-2.27-1.06-.3-.1-.52-.16-.73.16-.21.31-.84 1.05-1.03 1.27-.19.21-.38.24-.71.08-.33-.16-1.39-.5-2.65-1.58a9.86 9.86 0 0 1-1.84-2.26c-.19-.31-.02-.49.14-.65.15-.15.33-.39.5-.58.16-.2.21-.33.33-.55.11-.21.05-.4-.03-.56-.08-.16-.73-1.74-1-2.38-.26-.61-.53-.53-.73-.54h-.62c-.21 0-.55.08-.84.39-.29.31-1.1 1.07-1.1 2.6s1.13 3 1.29 3.21c.16.21 2.2 3.47 5.34 4.86.75.32 1.33.51 1.79.65.75.24 1.44.2 1.98.12.6-.09 1.96-.8 2.24-1.56.28-.76.28-1.41.2-1.55-.08-.13-.3-.21-.63-.37Z" />
      </svg>
      <span class="hidden sm:inline">WhatsApp</span>
    </a>

    <script>
      const navbar = document.getElementById('main-nav');
      const onScroll = () => {
        if (!navbar) return;
        if (window.scrollY > 50) navbar.classList.add('nav-scrolled');
        else navbar.classList.remove('nav-scrolled');
      };
      onScroll();
      window.addEventListener('scroll', onScroll);

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
          });
        },
        { threshold: 0.2 }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
